generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRoleEnum {
  USER
  ADMIN
}

enum FoodOrderStatusEnum {
  PENDING
  CANCELED
  DELIVERED
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  phoneNumber String?
  role        UserRoleEnum @default(USER)
  password    String
  address     String?
  isVerified  Boolean?
  orders      FoodOrder[]
}

model Food {
  id             Int             @id @default(autoincrement())
  name           String
  price          Int
  image          String
  ingredients    String
  foodCategoryId Int
  category       FoodCategory    @relation(fields: [foodCategoryId], references: [id])
  foodOrderItems FoodOrderItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model FoodCategory {
  id        Int      @id @default(autoincrement())
  name      String?
  foods     Food[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model FoodOrder {
  id             Int                 @id @default(autoincrement())
  userId         Int
  totalPrice     Int
  status         FoodOrderStatusEnum @default(PENDING)
  user           User                @relation(fields: [userId], references: [id])
  foodOrderItems FoodOrderItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model FoodOrderItem {
  id          Int       @id @default(autoincrement())
  quantity    Int
  foodId      Int
  foodOrderId Int
  food        Food      @relation(fields: [foodId], references: [id])
  order       FoodOrder @relation(fields: [foodOrderId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}